{
	"name": "wip",
	"description": "Work-in-progress inventory and prioritization CLI",
	"version": "0.0.0",
	"author": "Craig P. Motlin",
	"type": "module",
	"bin": {
		"wip": "./bin/run.js"
	},
	"dependencies": {
		"@oclif/core": "^4.9.0",
		"@oclif/plugin-help": "^6.2.38",
		"better-sqlite3": "^12.8.0",
		"chalk": "^5.6.2",
		"execa": "^9.6.1",
		"json5": "^2.2.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.0",
		"typescript": "^5.9.3"
	},
	"oclif": {
		"bin": "wip",
		"dirname": "wip",
		"commands": "./dist/commands",
		"plugins": [
			"@oclif/plugin-help"
		],
		"topicSeparator": " "
	},
	"scripts": {
		"build": "rm -rf dist && tsc -b",
		"typecheck": "tsc --noEmit"
	}
}
