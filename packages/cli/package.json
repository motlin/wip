{
	"name": "@wip/cli",
	"description": "Work-in-progress inventory and prioritization CLI",
	"version": "0.0.0",
	"author": "Craig P. Motlin",
	"type": "module",
	"bin": {
		"wip": "./bin/run.js"
	},
	"dependencies": {
		"@oclif/core": "^4.10.2",
		"@oclif/plugin-help": "^6.2.40",
		"@wip/shared": "workspace:*",
		"chalk": "^5.6.2",
		"execa": "^9.6.1"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.1"
	},
	"oclif": {
		"bin": "wip",
		"dirname": "wip",
		"commands": "./dist/commands",
		"plugins": [
			"@oclif/plugin-help"
		],
		"topicSeparator": " "
	},
	"scripts": {
		"build": "tsc -b",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	}
}
