{
  "name": "@wip/cli",
  "version": "0.0.0",
  "description": "Work-in-progress inventory and prioritization CLI",
  "author": "Craig P. Motlin",
  "bin": {
    "wip": "./bin/run.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "test": "vp test run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oclif/core": "^4.11.2",
    "@oclif/plugin-help": "^6.2.48",
    "@wip/shared": "workspace:*",
    "chalk": "^5.6.2",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "oclif": {
    "bin": "wip",
    "commands": "./dist/commands",
    "dirname": "wip",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  }
}
