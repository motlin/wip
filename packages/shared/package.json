{
	"name": "@wip/shared",
	"version": "0.0.0",
	"description": "Shared code between CLI and web packages",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -b tsconfig.build.json",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"better-sqlite3": "^12.8.0",
		"drizzle-orm": "^0.45.2",
		"execa": "^9.6.1",
		"json5": "^2.2.3",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.2",
		"pino-pretty": "^13.1.3",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
