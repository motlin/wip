{
  "name": "@wip/shared",
  "version": "0.0.0",
  "description": "Shared code between CLI and web packages",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./services/telemetry.js": {
      "types": "./src/services/telemetry.ts",
      "import": "./src/services/telemetry.ts"
    },
    "./services/traced-execa.js": {
      "types": "./src/services/traced-execa.ts",
      "import": "./src/services/traced-execa.ts"
    },
    "./services/logger-pino.js": {
      "types": "./src/services/logger-pino.ts",
      "import": "./src/services/logger-pino.ts"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "vp test run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.217.0",
    "@opentelemetry/instrumentation-http": "^0.217.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "json5": "^2.2.3",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@pollyjs/adapter-fetch": "^6.0.7",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
